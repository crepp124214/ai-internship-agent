# Test environment configuration
# Use with: APP_ENV=development python -m pytest ...

APP_NAME=AI Internship Agent Test
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000

# Use SQLite for tests (override in test code)
DATABASE_URL=sqlite://
REDIS_URL=redis://localhost:6379/0

# Mock LLM for tests
LLM_PROVIDER=mock
ENABLE_REAL_LLM=false

# Chroma DB
CHROMA_DB_PATH=:memory:

# Log level
LOG_LEVEL=INFO
LOG_FILE=

# Test secret key (not production)
SECRET_KEY=test-secret-key-for-unit-tests-only

# CORS
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# Rate limiting disabled for tests
RATE_LIMIT_BACKEND=memory
RATE_LIMIT_REQUESTS=1000
RATE_LIMIT_WINDOW_SECONDS=60

# No demo seeding in tests
SEED_DEMO_ON_BOOT=false
