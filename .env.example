# App
APP_NAME=AI Internship Agent
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000

# Database and cache
DATABASE_URL=sqlite:///./data/app.db
REDIS_URL=redis://localhost:6379/0

# LLM Provider Selection
# Options: mock | minimax | openai | deepseek | zhipu | dashscope | moonshot | siliconflow
LLM_PROVIDER=mock

# MiniMax (默认真实 provider，abab6.5s-chat 支持 Responses API + chat.completions fallback)
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimax.chat/v1
MINIMAX_MODEL=abab6.5s-chat

# OpenAI ( Responses API 优先，兼容 chat.completions)
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini

# DeepSeek
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# 智谱 AI (GLM 系列)
ZHIPU_API_KEY=
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4
ZHIPU_MODEL=glm-4

# 阿里云 DashScope (通义千问等)
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/api/v1
DASHSCOPE_MODEL=qwen-turbo

# Moonshot (Kimi)
MOONSHOT_API_KEY=
MOONSHOT_BASE_URL=https://api.moonshot.cn/v1
MOONSHOT_MODEL=moonshot-v1-8k

# SiliconFlow (聚合 API，支持多家模型)
SILICONFLOW_API_KEY=
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
SILICONFLOW_MODEL=deepseek-ai/deepseek-chat

# Vector store
CHROMA_DB_PATH=./data/vectors/chroma

# Logging
LOG_LEVEL=INFO
LOG_FILE=

# Security
# 生产/预发环境必须使用高强度 SECRET_KEY（至少 16 字符，且不能是占位值）。
SECRET_KEY=change-me-before-production

# CORS
# Comma-separated list parsed by pydantic-settings as JSON-style env input is not used here,
# so keep it as a plain string list only if you override it in deployment config.
CORS_ORIGINS=["http://localhost:3000","http://localhost:4173","http://localhost:4174","http://localhost:5173","http://127.0.0.1:3000","http://127.0.0.1:4173","http://127.0.0.1:4174","http://127.0.0.1:5173"]

# Security rate limit configuration
# RATE_LIMIT_BACKEND: auto | memory | redis
# - auto: REDIS_URL 不是默认 localhost 时优先 redis，否则 memory
# - memory: 强制内存限流
# - redis: 强制 redis 限流（redis 不可用时 fail-open）
RATE_LIMIT_BACKEND=auto
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60
 
# Observability
# Prometheus metrics available at /metrics (no auth required)

# Demo bootstrap
# Set to true only for local/demo environments that should auto-create the demo account on boot.
SEED_DEMO_ON_BOOT=false
