# Docker Compose demo stack defaults
APP_NAME=AI Internship Agent
APP_ENV=production
APP_DEBUG=false
APP_HOST=0.0.0.0
APP_PORT=8000

DATABASE_URL=postgresql://agent_user:agent_password@postgres:5432/internship_agent
REDIS_URL=redis://redis:6379/0

# Keep compose demos safe by default. Enable mock unless you intentionally wire a real provider.
LLM_PROVIDER=mock
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

CHROMA_DB_PATH=./data/vectors/chroma
LOG_LEVEL=INFO
LOG_FILE=

# Replace before any shared or production deployment.
SECRET_KEY=change-me-before-production

# Compose frontend is served at http://localhost:3000 by default.
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

RATE_LIMIT_BACKEND=redis
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# Opt in explicitly if you want the demo account to be created on boot.
SEED_DEMO_ON_BOOT=false
